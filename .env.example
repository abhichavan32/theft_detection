# Django Backend Settings 
# For Render deployment: set DEBUG=False
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-use-strong-random-key
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.onrender.com

# Database Configuration
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# CORS for React Frontend (Vercel)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ML Models
ML_MODELS_DIR=theft_detection/ml_models

# Logging
LOG_LEVEL=INFO
